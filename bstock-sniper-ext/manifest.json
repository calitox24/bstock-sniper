{
  "manifest_version": 3,
  "name": "BStock Sniper",
  "version": "1.0",
  "description": "Sniper para subastas BStock - controla tus pujas desde un panel",
  "permissions": ["tabs", "storage", "alarms", "scripting", "windows", "cookies"],
  "host_permissions": [
    "https://bstock.com/*",
    "https://www.bstock.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "BStock Sniper"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://bstock.com/buy/listings/details/*",
        "https://www.bstock.com/buy/listings/details/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bstock-sniper@celularesrd",
      "strict_min_version": "109.0"
    }
  }
}
